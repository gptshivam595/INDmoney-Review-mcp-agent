PULSE_DATABASE_PATH=data/pulse.db
PULSE_PRODUCTS_PATH=products.yaml
PULSE_DEFAULT_REVIEW_WINDOW_WEEKS=10
PULSE_TIMEZONE=Asia/Kolkata
PULSE_LOG_LEVEL=INFO
PULSE_DOCS_MCP_TRANSPORT=http
PULSE_DOCS_MCP_BASE_URL=http://127.0.0.1:8000
PULSE_DOCS_MCP_TIMEOUT_SECONDS=30
PULSE_GMAIL_MCP_TRANSPORT=http
PULSE_GMAIL_MCP_BASE_URL=http://127.0.0.1:8000
PULSE_GMAIL_MCP_TIMEOUT_SECONDS=30
PULSE_API_CORS_ORIGINS=http://localhost:3000
PULSE_CONFIRM_SEND=false
PULSE_SCHEDULER_ENABLED=false
PULSE_SCHEDULER_DAY_OF_WEEK=0
PULSE_SCHEDULER_HOUR_24=9
PULSE_SCHEDULER_MINUTE=0
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CLIENT_SECRET_FILE=C:/path/to/client_secret.json
GOOGLE_MCP_PROFILE=shivam
GOOGLE_TOKEN_PATH=token.json
